@page "/admin/settings/esp32-s3-devkitc-1"
@using MESS.Services.CRUD.DevelopmentBoardSettings
@using MESS.Services.DTOs.DevelopmentBoardSettings
@using Microsoft.AspNetCore.Authorization
@inject IDevelopmentBoardSettingsService DevelopmentBoardSettingsService
@inject IToastService ToastService

@attribute [Authorize(Roles = "Administrator")]

<PageTitle>ESPRESSIF ESP32-S3 DevKitC-1 Settings</PageTitle>

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-end mb-3">
                <a class="btn btn-outline-secondary" href="/admin/settings">Back to Settings</a>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">ESPRESSIF ESP32-S3 DevKitC-1 Network Settings</h4>
                </div>
                <div class="card-body">
                    @if (Settings is null)
                    {
                        <div class="alert alert-info">
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            Loading development board settings...
                        </div>
                    }
                    else
                    {
                        <EditForm Model="Settings" OnValidSubmit="SaveSettingsAsync" OnInvalidSubmit="HandleInvalidSubmit">
                            <DataAnnotationsValidator />

                            <div class="alert alert-warning">
                                <strong>Enter the network details the ESP32 board uses to talk to MESS.</strong>
                                <br />
                                Save the board host information, Wi-Fi credentials, and the software endpoint the board should use.
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <div class="form-check form-switch">
                                        <InputCheckbox class="form-check-input" id="enableBoard" @bind-Value="Settings.IsEnabled" />
                                        <label class="form-check-label" for="enableBoard">
                                            Enable Development Board Integration
                                        </label>
                                    </div>
                                    <small class="text-muted d-block mt-1">
                                        Disable this if the board should not connect to the software yet
                                    </small>
                                </div>
                            </div>

                            <div class="row g-3 mb-3">
                                <div class="col-md-6">
                                    <label class="form-label">Device Name <span class="text-danger">*</span></label>
                                    <InputText class="form-control" @bind-Value="Settings.DeviceName" placeholder="ESPRESSIF ESP32-S3 DevKitC-1" />
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">Connection Mode</label>
                                    <InputSelect class="form-select" @bind-Value="Settings.ConnectionMode">
                                        <option value="WiFi">Wi-Fi</option>
                                        <option value="Ethernet">Ethernet</option>
                                        <option value="USB">USB</option>
                                    </InputSelect>
                                </div>
                            </div>

                            <div class="row g-3 mb-3">
                                <div class="col-md-6">
                                    <label class="form-label">Board IP Address / Hostname</label>
                                    <InputText class="form-control" @bind-Value="Settings.HostAddress" placeholder="192.168.1.50 or esp32-board.local" />
                                    <small class="text-muted">This is the network address MESS will use to reach the board</small>
                                </div>

                                <div class="col-md-3">
                                    <label class="form-label">Port</label>
                                    <InputNumber class="form-control" @bind-Value="Settings.Port" />
                                </div>

                                <div class="col-md-3">
                                    <label class="form-label">Timeout (ms)</label>
                                    <InputNumber class="form-control" @bind-Value="Settings.TimeoutMilliseconds" />
                                </div>
                            </div>

                            <div class="row g-3 mb-3">
                                <div class="col-md-6">
                                    <label class="form-label">Board API Path</label>
                                    <InputText class="form-control" @bind-Value="Settings.ApiPath" placeholder="/api/device" />
                                    <small class="text-muted">Example: <code>/api/device</code> or <code>/status</code></small>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">Software Endpoint</label>
                                    <InputText class="form-control" @bind-Value="Settings.SoftwareEndpoint" placeholder="https://your-mess-server/api/board-events" />
                                    <small class="text-muted">Use the MESS endpoint the board should post data to</small>
                                </div>
                            </div>

                            <div class="row g-3 mb-3">
                                <div class="col-md-6">
                                    <label class="form-label">Wi-Fi SSID</label>
                                    <InputText class="form-control" @bind-Value="Settings.WifiSsid" placeholder="PlantFloorWiFi" />
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">Wi-Fi Password</label>
                                    <InputText class="form-control" type="password" @bind-Value="Settings.WifiPassword" placeholder="Enter Wi-Fi password" />
                                </div>
                            </div>

                            <div class="row g-3 mb-3">
                                <div class="col-md-6">
                                    <label class="form-label">Access Token</label>
                                    <InputText class="form-control" @bind-Value="Settings.AccessToken" placeholder="Shared token or API key" />
                                    <small class="text-muted">Use this if the board and software authenticate requests with a shared key</small>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Notes</label>
                                <InputTextArea class="form-control" @bind-Value="Settings.Notes" rows="3" placeholder="Add any setup details for this board..." />
                            </div>

                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-success" disabled="@IsSaving">
                                    @if (IsSaving)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                    }
                                    Save Settings
                                </button>

                                <button type="button" class="btn btn-outline-secondary" @onclick="TestConnectionAsync" disabled="@(IsSaving || IsTesting)">
                                    @if (IsTesting)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                        <text>Testing...</text>
                                    }
                                    else
                                    {
                                        <span>Test Connection</span>
                                    }
                                </button>
                            </div>

                            @if (!string.IsNullOrEmpty(ConnectionTestMessage))
                            {
                                <div class="alert @ConnectionTestAlertClass mt-3">
                                    @ConnectionTestMessage
                                </div>
                            }
                        </EditForm>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private DevelopmentBoardSettingsDTO? Settings;
    private bool IsSaving;
    private bool IsTesting;
    private string? ConnectionTestMessage;
    private string ConnectionTestAlertClass = "alert-info";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Settings = await DevelopmentBoardSettingsService.GetSettingsAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Failed to load development board settings. If this is a new update, restart the app so the database migration can create the table. Details: {ex.Message}");
        }
    }

    private async Task SaveSettingsAsync()
    {
        IsSaving = true;
        ConnectionTestMessage = null;

        try
        {
            Settings = await DevelopmentBoardSettingsService.UpdateSettingsAsync(Settings!);
            ToastService.ShowSuccess("Development board settings saved successfully");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Failed to save development board settings: {ex.Message}");
        }
        finally
        {
            IsSaving = false;
        }
    }

    private void HandleInvalidSubmit()
    {
        ToastService.ShowWarning("Please correct the validation errors before saving");
    }

    private async Task TestConnectionAsync()
    {
        IsTesting = true;
        ConnectionTestMessage = null;

        try
        {
            bool success = await DevelopmentBoardSettingsService.TestConnectionAsync();

            if (success)
            {
                ConnectionTestAlertClass = "alert-success";
                ConnectionTestMessage = "Successfully connected to the development board.";
            }
            else
            {
                ConnectionTestAlertClass = "alert-danger";
                ConnectionTestMessage = "Failed to connect to the development board. Check the host address, port, and board network access.";
            }
        }
        catch (Exception ex)
        {
            ConnectionTestAlertClass = "alert-danger";
            ConnectionTestMessage = $"Connection test error: {ex.Message}";
        }
        finally
        {
            IsTesting = false;
        }
    }
}
