@using MESS.Services.DTOs.WorkInstructions.File
@using MESS.Services.Files.WorkInstructions

@if (Visible)
{
    <FluentDialog Open="@Visible" OnDismiss="Close">
        
        <FluentDialogHeader>
            <h5 class="fw-semibold text-dark mb-1">Export Work Instruction</h5>
            <FluentDivider></FluentDivider>
        </FluentDialogHeader>

        <FluentDialogBody>
            <p>@WorkInstruction?.Title - Version @WorkInstruction?.Version</p>
            @if (_isDownloadInProgress)
            {
                <div class="mt-3">
                    <div class="progress">
                        <div class="progress-bar"
                             role="progressbar"
                             style="width:@_progressPercent%">
                            @_progressPercent%
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(_progressMessage))
                    {
                        <small class="text-muted">@_progressMessage</small>
                    }
                </div>
            }
        </FluentDialogBody>

        <FluentDialogFooter>
            @if (WorkInstruction is not null)
            {
                <WorkInstructionExportButton 
                    @ref="_exportButton"
                    WorkInstruction="WorkInstruction"
                    OnDownloadComplete="Close"
                    OnDownloadStateChanged="HandleDownloadStateChanged"
                    OnProgressChanged="HandleProgressChanged"/>
            }

            <button type="button"
                    class="btn btn-sm btn-outline-secondary"
                    @onclick="CancelExportAsync">
                Cancel
            </button>
        </FluentDialogFooter>
    </FluentDialog>
}

@code {
    /// <summary>
    /// Gets or sets the <see cref="WorkInstructionFileDTO"/> to be exported.
    /// </summary>
    [Parameter, EditorRequired]
    public WorkInstructionFileDTO? WorkInstruction { get; set; }

    /// <summary>
    /// Gets or sets a value indicating whether the dialog is visible.
    /// </summary>
    [Parameter]
    public bool Visible { get; set; }

    /// <summary>
    /// Event callback that is invoked when the <see cref="Visible"/> parameter changes.
    /// </summary>
    [Parameter]
    public EventCallback<bool> VisibleChanged { get; set; }
    
    private bool _isDownloadInProgress;
    private int _progressPercent;
    private string _progressMessage = "";
    private WorkInstructionExportButton? _exportButton;

    private async Task HandleDownloadStateChanged(bool downloading)
    {
        _isDownloadInProgress = downloading;
        await InvokeAsync(StateHasChanged);
    }
    
    private Task HandleProgressChanged(ExportProgress progress)
    {
        _progressPercent = progress.Percent;
        _progressMessage = progress.Message;
        return InvokeAsync(StateHasChanged);
    }

    private async Task Close()
    {
        Visible = false;
        await VisibleChanged.InvokeAsync(Visible);
    }

    /// <summary>
    /// Stops an in-flight export (if any) and closes the dialog — Cancel must dismiss the popup,
    /// not only cancel generation when a download is running.
    /// </summary>
    private async Task CancelExportAsync()
    {
        _exportButton?.CancelExport();
        await Close();
    }
}