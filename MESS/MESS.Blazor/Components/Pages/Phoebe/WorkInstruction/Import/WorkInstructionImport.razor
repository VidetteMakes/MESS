@using MESS.Data.Models
@using MESS.Services.DTOs
@using MESS.Services.DTOs.WorkInstructions.Form
@using MESS.Services.Files.WorkInstructions
@using MESS.Services.UI.WorkInstructionImport
@using Serilog
@inject IWorkInstructionFileService WorkInstructionFileService
@inject IWorkInstructionImportService WorkInstructionImportService
@inject IToastService ToastService

<FluentCard Width="400" Class="m-0 w-100">
    <div class="d-flex align-items-center">
        <button @onclick="Import" class="btn btn-primary" disabled="@(IsImporting || File == null)">
            Import File
        </button>
        <InputFile OnChange="LoadFile" accept=".xlsx" class="form-control mb-3"/>
    </div>

    @if (IsImporting)
    {
        <div class="mt-3">
            <div class="progress">
                <div class="progress-bar progress-bar-striped progress-bar-animated" style="width: 100%">
                    Importing...
                </div>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(StatusMessage))
    {
        <div class="alert alert-info mt-3">
            @StatusMessage
        </div>
    }
</FluentCard>


@code {
    /// <summary>
    /// Event callback triggered when the import process is complete.
    /// Passes the imported <see cref="WorkInstruction"/> as a parameter.
    /// </summary>
    [Parameter]
    public EventCallback<WorkInstructionFormDTO> OnImportComplete { get; set; }
    
    private IBrowserFile? File { get; set; }
    private bool IsImporting { get; set; }
    private string? StatusMessage { get; set; }
    private ImportStatus? FileStatus { get; set; }
    private bool ImportComplete { get; set; }
    
    private async Task Import()
    {
        IsImporting = true;
        ImportComplete = false;
        StatusMessage = null;

        if (File == null)
        {
            IsImporting = false;
            ImportComplete = true;
            ToastService.ShowError("File is null. Please try again.");
            return;
        }

        try
        {
            // Step 1: Convert uploaded file to file-layer DTO
            var fileImportResult = await WorkInstructionFileService.ImportFromXlsx(File);

            if (fileImportResult.Status == ImportStatus.Error)
            {
                // Full detail in logs only; user sees a safe summary (file errors may contain paths or parser internals).
                Log.Warning("Work instruction spreadsheet import failed: {Detail}", fileImportResult.ImportError?.ToString());
                StatusMessage = "The spreadsheet could not be read. Ensure it is a valid work instruction export and try again.";
                ToastService.ShowError(StatusMessage, 10000);
                return;
            }

            var fileDto = fileImportResult.WorkInstruction;
            if (fileDto == null)
            {
                ToastService.ShowError("Imported file contained no work instruction data.");
                return;
            }

            // Step 2: Use the import service to resolve references and validate
            var importResult = await WorkInstructionImportService.ImportAsync(fileDto);

            if (!importResult.Success)
            {
                // Domain validation messages: still shown in-page for technicians; logged in full for support.
                StatusMessage = string.Join("; ", importResult.Errors);
                Log.Warning("Work instruction import validation failed: {Errors}", StatusMessage);
                ToastService.ShowError("Import validation failed. Review the details shown below.", 10000);
                return;
            }

            // Step 3: Success — get the resolved WorkInstructionFormDTO
            var resolvedFormDto = importResult.WorkInstruction;

            // Notify parent (passing resolved form DTO)
            await OnImportComplete.InvokeAsync(resolvedFormDto);

            ImportComplete = true;
        }
        catch (Exception ex)
        {
            // Unexpected failures: full detail in logs; generic message in UI.
            Log.Error(ex, "Unexpected error during work instruction import");
            ToastService.ShowError("Something went wrong while importing. Please try again.", 10000);
        }
        finally
        {
            // Ensures spinner clears on every exit path from the try (including returns).
            IsImporting = false;
        }
    }

    private void LoadFile(InputFileChangeEventArgs obj)
    {
        File = obj.File;
    }

}